# Copiar para `.env.local` ou `.env` (nunca commitar valores reais).
# CRA expõe apenas variáveis com prefixo REACT_APP_*

REACT_APP_FIREBASE_API_KEY=
REACT_APP_FIREBASE_AUTH_DOMAIN=
REACT_APP_FIREBASE_PROJECT_ID=
REACT_APP_FIREBASE_STORAGE_BUCKET=
REACT_APP_FIREBASE_MESSAGING_SENDER_ID=
REACT_APP_FIREBASE_APP_ID=

# Opcional: App Check token (vide docs/FIREBASE_SETUP.md). Ex.: reCAPTCHA v3 para web.
# REACT_APP_FIREBASE_RECAPTCHA_SITE_KEY=

# Opcional: erro em produção
# REACT_APP_SENTRY_DSN=
